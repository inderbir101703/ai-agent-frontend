# ── Development ──────────────────────────────────────────────────────────────
# Backend URL used only by the Vite dev-proxy (never sent to the browser)
API_TARGET=http://localhost:3000

# ── All environments ─────────────────────────────────────────────────────────
# Leave empty to use relative URLs (recommended — works with all proxy setups)
# Set to full URL only if you deploy WITHOUT a reverse proxy and need direct calls
VITE_API_URL=
